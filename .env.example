# ─────────────────────────────────────────────────────────────────────────────
# Trivia Quiz — Environment Variables Template
# Copy this file:
#   cp .env.example backend/.env        (for the backend service)
#   cp frontend/.env.example frontend/.env  (for the Vite frontend)
#
# DO NOT commit .env files with real values to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────

# Port the Express + Socket.IO server listens on
PORT=3001

# Comma-separated list of allowed CORS origins (frontend URLs)
# Local dev:      http://localhost:5173
# Production:     https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Session time-to-live in milliseconds before inactive sessions are purged
# Default: 2 hours (7200000 ms)
SESSION_TTL_MS=7200000

# How often (ms) to run the session cleanup sweep
# Default: 5 minutes (300000 ms)
SESSION_CLEANUP_INTERVAL_MS=300000

# Answerer's countdown timer in seconds (PRD: 30s)
ANSWER_TIMER_SECONDS=30

# Reveal suspense countdown in seconds (PRD: 5s)
REVEAL_TIMER_SECONDS=5

# Node environment: development | production | test
NODE_ENV=development

# ── Frontend (Vite — must be prefixed with VITE_) ────────────────────────────
# These are set in frontend/.env (not this root file).
# Shown here for documentation purposes.

# Full URL to the backend service
# Local dev:   http://localhost:3001
# Production:  https://your-app.railway.app
VITE_BACKEND_URL=http://localhost:3001

# Socket.IO path (default is /socket.io — only change if using a proxy rewrite)
VITE_SOCKET_PATH=/socket.io
